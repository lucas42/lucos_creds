<html>
	<head>
		<title>LucOs Credentials - Edit Credential</title>
		<meta name="viewport" content="initial-scale=1.0, user-scalable=no, width=device-width" />
		<link href="/style.css" rel="stylesheet" />
		<link rel="icon" href="/icon.png" />
		<link rel="manifest" href="/manifest.json" />
	</head>
	<body>
		<lucos-navbar bg-colour="#334">Creds</lucos-navbar>
		<nav id="breadcrumbs">
			<a href="/">Credentials</a> &gt;
			<span>Update Simple Credential</span>
		</nav>
		<main>
			<% if (system === 'lucos_creds' && environment === 'production') { %>
			<div class="self-deploy-warning">
				<strong><span aria-hidden="true">⚠ </span>Extra step required after saving</strong><br>
				Updating a credential here is not enough on its own. You must also regenerate <code>LUCOS_DEPLOY_ENV_BASE64</code> and update it in CircleCI project settings — otherwise the next self-deploy will silently overwrite your change.<br>
				<a href="https://github.com/lucas42/lucos/blob/main/docs/runbooks/update-lucos-creds-production.md">See the runbook for step-by-step instructions.</a>
			</div>
			<% } %>
			<% if (error) { %>
				<div class='error'><%= error %></div>
			<% } %>
			<form action="/update-simple-credential" method="post" class="entry-form">
				<span class="form-field"><label for="system" title="The system which'll use this credential">System</label><input type="text" name="system" id="system" value="<%= system %>" /></span>
				<span class="form-field"><label for="environment" title="The environment of the system this credential will be availble in">Environment</label><input type="text" name="environment" id="environment" value="<%= environment %>" /></span>
				<span class="form-field"><label for="key" title="The name of the environment variable the system will be able to access this credential in (Transformed to uppercase)">Key</label><input type="text" name="key" id="key" value="<%= key?.toUpperCase() %>" /></span>
				<span class="form-field"><label for="value" title="The value of the credential - stored encrypted">Value</label><textarea name="value" id="value" rows="6" spellcheck="false" autocorrect="off" autocapitalize="off" autocomplete="off"><%= value %></textarea></span>
				<span class="form-field"><input type="submit" value="Save" class="inline-button add-button" /></span>
			</form>
		</main>
		<script type="text/javascript" src="/client.js"></script>
	</body>
</html>